# =============================================================================
# SpiceLedger environment template
# Choose one setup path:
#   Local MySQL:  cp .env.local.example .env
#   Docker:       cp .env.docker.example .env
# =============================================================================

APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=spice_ledger

JWT_SECRET=supersecretjwtkey123!
ACCESS_TOKEN_DURATION=30m
REFRESH_TOKEN_DURATION=168h

BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=secret123

CONTROL_GRPC_PORT=50051
MARKET_GRPC_PORT=50052
PROXY_PORT=8080

ACCOUNT_GRPC_URL=
MARKET_GRPC_URL=

LOG_LEVEL=debug
