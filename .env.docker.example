# =============================================================================
# SpiceLedger — Docker Compose (service DNS hostnames)
# Copy to .env:  cp .env.docker.example .env
# =============================================================================

APP_ENV=development

# Database (Docker service name)
DB_HOST=db
DB_PORT=3306
DB_HOST_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=spice_ledger

# Auth — change before staging/production
JWT_SECRET=supersecretjwtkey123!
ACCESS_TOKEN_DURATION=30m
REFRESH_TOKEN_DURATION=168h
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=secret123

# Service ports (host mapping)
CONTROL_GRPC_PORT=50051
MARKET_GRPC_PORT=50052
REST_PORT=8082
GRAPHQL_PORT=8081
PROXY_PORT=8080

# Inter-service URLs (Docker internal DNS — overridden in docker-compose.yaml)
ACCOUNT_GRPC_URL=control:50051
MARKET_GRPC_URL=market:50052
ACCOUNT_SERVICE_URL=http://rest:8082
GRAPHQL_GATEWAY_URL=http://graphql:8081

LOG_LEVEL=debug
