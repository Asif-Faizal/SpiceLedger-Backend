{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}"
        },
        {
            "name": "Run Control Service",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/control/cmd/control/main.go",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "DB_HOST": "localhost"
            }
        },
        {
            "name": "Run REST Service",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/rest/cmd/rest/main.go",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PORT": "8082",
                "ACCOUNT_GRPC_URL": "localhost:50051"
            }
        },
        {
            "name": "Run Proxy Service",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/proxy/main.go",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "ACCOUNT_SERVICE_URL": "http://localhost:8082",
                "GRAPHQL_GATEWAY_URL": "http://localhost:4000",
                "PROXY_PORT": "8080"
            }
        }
    ]
}