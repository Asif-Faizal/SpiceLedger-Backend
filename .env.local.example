# =============================================================================
# SpiceLedger — Local development (Homebrew MySQL on localhost)
# Copy to .env:  cp .env.local.example .env
# =============================================================================

APP_ENV=development

# Database (local MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=spice_ledger

# Auth
JWT_SECRET=supersecretjwtkey123!
ACCESS_TOKEN_DURATION=30m
REFRESH_TOKEN_DURATION=168h
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=secret123

# Service ports
CONTROL_GRPC_PORT=50051
MARKET_GRPC_PORT=50052
PROXY_PORT=8080

# gRPC URLs (localhost for native `go run`)
ACCOUNT_GRPC_URL=localhost:50051
MARKET_GRPC_URL=localhost:50052

LOG_LEVEL=debug
